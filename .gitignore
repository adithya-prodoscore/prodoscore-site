# ============================================================
# WORDPRESS — KINSTA DEPLOYMENT
# Strategy: Git tracks your custom theme only.
# Plugins are managed directly on Kinsta, not through Git.
# ============================================================


# --- WORDPRESS CORE ---
# Kinsta manages core updates. We never touch these.
wp-admin/
wp-includes/
wp-*.php
xmlrpc.php
license.txt
readme.html


# --- SERVER CONFIG ---
# These belong to Kinsta's server. Never overwrite them.
nginx.conf
.htaccess


# --- CONFIG & SECRETS ---
# Never commit credentials or environment-specific config.
wp-config.php
wp-config-sample.php
.env
.env.*


# --- PLUGINS ---
# 1. Un-ignore the plugins folder itself (don't add a trailing slash here)
!wp-content/plugins

# 2. Ignore everything INSIDE the plugins folder by default
wp-content/plugins/*

# 3. NOW the exceptions will work
!wp-content/plugins/advanced-custom-fields/


# --- MU-PLUGINS ---
# Kinsta's internal system plugins. Never touch these.
wp-content/mu-plugins/


# --- UPLOADS & MEDIA ---
# Client-owned content. Only flows DOWN via DevKinsta pull.
# Never committed, never pushed.
wp-content/uploads/
wp-content/blogs.dir/


# --- WORDPRESS STATE FILES ---
# Generated or environment-specific. Not portable across environments.
wp-content/upgrade/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php


# --- CACHE & GENERATED FILES ---
wp-content/cache/
wp-content/autoptimize/


# --- LANGUAGES ---
# Translation files are generated/updated by WordPress automatically.
wp-content/languages/


# --- THEMES ---
# We track ONLY our custom theme.
# All default WordPress themes are ignored.
wp-content/themes/twenty*/


# --- INDEX.PHP SAFETY FILES ---
# WordPress places empty index.php files everywhere as a security measure.
# We ignore them globally but keep the one inside our theme.
**/index.php
!wp-content/themes/prodoscore_theme/index.php


# --- THEME BUILD ARTIFACTS ---
# Scoped to your theme so other folders aren't affected.
wp-content/themes/prodoscore_theme/node_modules/
wp-content/themes/prodoscore_theme/dist/
wp-content/themes/prodoscore_theme/.parcel-cache
wp-content/themes/prodoscore_theme/npm-debug.log*


# --- OS & EDITOR ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log